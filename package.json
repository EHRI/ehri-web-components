{
  "name": "@ehri/web-components",
  "version": "0.0.3",
  "license": "EUPL-1.2",
  "homepage": "https://github.com/EHRI/ehri-web-components",
  "bugs": "https://github.com/EHRI/ehri-web-components/issues",
  "readme": "https://github.com/EHRI/ehri-web-components/README.md",
  "description": "A small plain JS library for embedding info about EHRI portal items in web pages.",
  "main": "ehri-web-components.js",
  "devDependencies": {
    "esbuild": "^0.27.3"
  },
  "files": ["dist"],
  "scripts": {
    "build": "npm run build:dev && npm run build:browser",
    "build:dev": "esbuild ehri-web-components.js --bundle --loader:.css=text --loader:.html=text --outfile=dist/ehri-web-components.js",
    "build:browser": "esbuild ehri-web-components.js --bundle --minify --sourcemap --loader:.css=text --loader:.html=text --outfile=dist/ehri-web-components.min.js --platform=browser --target=es2015",
    "serve": "esbuild ehri-web-components.js --serve=3000 --bundle --loader:.css=text --loader:.html=text --outdir=dist --servedir=.",
    "prepublishOnly": "npm run build"
  }
}
